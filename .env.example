# ====================================================================
# Configuration du bot WhatsApp
# Toutes les variables sont injectées par XHRIS Host à partir des champs
# du formulaire de déploiement (sauf indication contraire).
# ====================================================================

# SESSION (OBLIGATOIRE — généré sur le site de pairing du bot)
# Accepte les formats : CHRIS_MD_xxx, WABOT_xxx, XHRIS_xxx ou base64 brut
SESSION_ID=

# Numéro propriétaire (avec indicatif, sans + — ex: 237690768603)
OWNER_NUMBER=

# Numéros sudo séparés par des virgules
SUDO=

# Nom affiché du bot
BOT_NAME=MonBot

# Préfixe des commandes
PREFIX=.

# ====================================================================
# OPTIONNEL — Si non défini, le bot tourne en mode sans persistence
# ====================================================================

# PostgreSQL pour persister sessions / warns / groupes / AFK
DATABASE_URL=

# Limite warns avant kick
WARN_LIMIT=3

# Clés IA (utilisées par certaines commandes)
GPT_KEY=
GEMINI_KEY=

# ====================================================================
# AUTO — injectées par XHRIS Host, ne pas modifier
# ====================================================================
# XHRIS_API_URL=
# XHRIS_API_KEY=
# XHRIS_DEPLOY_TYPE=
